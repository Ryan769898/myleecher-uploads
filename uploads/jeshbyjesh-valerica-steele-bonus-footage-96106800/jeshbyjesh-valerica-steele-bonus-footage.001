<div id="search-modal"
    class="fixed inset-0 z-[100] hidden bg-[#0a0a0a]/95 flex items-start justify-center pt-20 px-4 transition-opacity duration-300 opacity-0 pointer-events-none data-[open]:opacity-100 data-[open]:pointer-events-auto">
    
    <div
        class="w-full max-w-2xl bg-surface-1 rounded-2xl shadow-2xl overflow-hidden border border-outline/20 transform scale-95 transition-transform duration-300 data-[open]:scale-100">
        
        <div class="flex flex-col md:flex-row items-center p-6 gap-4">
            <div
                class="relative flex items-center gap-3 flex-grow bg-surface-variant/10 border border-white/5 rounded-full px-5 py-3 w-full transition-colors focus-within:bg-surface-variant/20">
                <span class="material-symbols-outlined text-on-surface-variant text-2xl">search</span>
                <input type="text" id="search-input" placeholder="Search for movies, stars, tags..."
                    class="w-full bg-transparent text-on-surface text-lg focus:outline-none placeholder:text-on-surface-variant/50">
                <button id="search-close"
                    class="w-10 h-10 flex items-center justify-center text-on-surface-variant hover:text-on-surface rounded-full hover:bg-white/10 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <button id="search-submit-btn"
                class="primary-btn px-8 py-4 md:py-3 rounded-full text-base font-bold whitespace-nowrap w-full md:w-auto shadow-lg shadow-primary/20 hover:scale-105 active:scale-95 transition-all">
                Search Now
            </button>
        </div>

        
        <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2 hidden">
            
        </div>

        
        <div id="search-initial" class="p-8 text-center text-on-surface-variant">
            <p class="mb-2">Hit enter to search</p>
        </div>
    </div>
</div>


