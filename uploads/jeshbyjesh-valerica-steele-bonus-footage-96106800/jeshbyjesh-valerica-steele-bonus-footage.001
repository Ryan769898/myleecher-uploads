<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script src="/dist/js/app.js"></script>

    
    <style>
         
        .vjs-backward-button, .vjs-forward-button {
            cursor: pointer;
            display: flex !important;
            align-items: center;
            justify-content: center;
        }
        .vjs-backward-button .material-symbols-outlined,
        .vjs-forward-button .material-symbols-outlined {
            font-size: 24px !important;
        }
         
        .video-js .vjs-control-bar {
            align-items: center !important;
        }
    </style>

    <div id="streamModal"
        class="fixed inset-0 z-[100] hidden bg-black/95 flex flex-col items-center justify-center p-2 md:p-6 backdrop-blur-md">
        <div class="w-full flex justify-end mb-3 md:mb-4 px-2 md:px-0"
            style="max-width: min(100%, calc((100vh - 200px) * 16/9));">
            <button onclick="closeStreamModal()"
                class="bg-surface-variant/50 hover:bg-primary rounded-full w-10 h-10 md:w-12 md:h-12 flex items-center justify-center text-white transition-colors">
                <span class="material-symbols-outlined text-xl md:text-2xl">close</span>
            </button>
        </div>
        <div class="w-full bg-black rounded-lg md:rounded-2xl shadow-2xl overflow-hidden border border-white/10 flex flex-col"
            style="max-width: min(100%, calc((100vh - 200px) * 16/9));">
            <div class="aspect-video w-full bg-black">
                <video id="hlsPlayer" class="video-js vjs-default-skin vjs-big-play-centered w-full h-full" controls
                    playsinline crossorigin="anonymous" poster="https://xmoviescdn.online/2026/05/jeshbyjesh-valerica-steele-bonus-footage-xmoviesforyou-69fdcd29c73b9.webp">
                </video>
            </div>
            <div class="p-4 md:p-6 bg-surface text-center flex-shrink-0">
                <h3 class="text-lg md:text-xl font-bold flex items-center justify-center gap-2 text-white">
                    <span class="material-symbols-outlined text-primary">play_circle</span> XMFU HD Server
                </h3>
                <p class="text-on-surface-variant/80 text-xs md:text-sm mt-1">High-speed streaming without
                    interruptions.</p>
            </div>
        </div>
    </div>

    
    <link href="https://cdn.jsdelivr.net/npm/video.js@8.10.0/dist/video-js.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/videojs-contrib-ads/7.5.2/videojs.ads.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/videojs-ima@2.6.0/dist/videojs.ima.min.css" rel="stylesheet" />

    <script src="https://cdn.jsdelivr.net/npm/video.js@8.10.0/dist/video.min.js"></script>
    <script src="https://imasdk.googleapis.com/js/sdkloader/ima3.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/videojs-contrib-ads/7.5.2/videojs.ads.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/videojs-ima@2.6.0/dist/videojs.ima.min.js"></script>

    <script>
        let isPlayerInitialized = false;
        async function openStreamModal() {
            document.getElementById('streamModal').classList.remove('hidden');
            
            if (!isPlayerInitialized) {
                
                const player = videojs('hlsPlayer', {
                    fluid: true,
                    preload: 'auto'
                });

                
                player.ready(() => {
                    
                    const backwardButton = player.controlBar.addChild('button', {
                        className: 'vjs-visible-text vjs-backward-button',
                        controlText: 'Backward 10s'
                    }, 1); 
                    backwardButton.el().innerHTML = '<span class="material-symbols-outlined">replay_10</span>';
                    backwardButton.on('click', () => {
                        player.currentTime(Math.max(0, player.currentTime() - 10));
                    });

                    
                    const forwardButton = player.controlBar.addChild('button', {
                        className: 'vjs-visible-text vjs-forward-button',
                        controlText: 'Forward 10s'
                    }, 2);
                    forwardButton.el().innerHTML = '<span class="material-symbols-outlined">forward_10</span>';
                    forwardButton.on('click', () => {
                        player.currentTime(Math.min(player.duration(), player.currentTime() + 10));
                    });
                });
                
                const adTagUrl = 'https://a.adtng.com/get/10016778';

                const imaOptions = {
                    id: 'hlsPlayer',
                    adTagUrl: adTagUrl,
                    showControlsForAds: true
                };
                
                player.ima(imaOptions);
                
                
                player.ima.initializeAdDisplayContainer();
                
                isPlayerInitialized = true;

                
                let midrollPlayed = false;
                player.on('timeupdate', () => {
                    const duration = player.duration();
                    if (!midrollPlayed && duration > 0 && player.currentTime() >= (duration / 2)) {
                        midrollPlayed = true;
                        player.ima.changeAdTag(adTagUrl);
                        player.ima.requestAds();
                    }
                });
                

                try {
                    
                    const videoId = "177822645207511";
                    const target = "dedi_1";
                    const response = await fetch(`/api/stream/${videoId}?target=${target}`);
                    const data = await response.json();
                    
                    if (!data.url) {
                        throw new Error('Failed to get stream URL');
                    }
                    
                    
                    player.src({
                        src: data.url,
                        type: "application/x-mpegURL"
                    });
                    
                    player.play();

                    
                    
                    let geoData = { ip: "", country_code: "" };
                    try {
                        const geoRes = await fetch("https://ipapi.co/json/").catch(() => null);
                        if (geoRes && geoRes.ok) geoData = await geoRes.json();
                    } catch(e) {}

                    fetch("/api/visit/video/177822645207511", {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            url: window.location.href, 
                            referer: document.referrer,
                            ip: geoData.ip,
                            location: geoData.country_code
                        })
                    }).catch(() => {});
                    

                } catch (error) {
                    console.error('Failed to load stream:', error);
                    alert('Failed to load video stream. Please try again.');
                }
            } else {
                const player = videojs('hlsPlayer');
                player.play();
            }
        }
        
        function closeStreamModal() {
            document.getElementById('streamModal').classList.add('hidden');
            if (isPlayerInitialized) {
                videojs('hlsPlayer').pause();
            }
        }
    </script>
    

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const postId = "155822071302327";

            
            function formatDate(isoStr) {
                const date = new Date(isoStr);
                return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            }

            
            function renderCard(post) {
                let studioHtml = '';
                if (post.studios && post.studios.length > 0) {
                    studioHtml = `<span class="text-primary font-medium truncate max-w-[100px]">${post.studios[0].name}</span> &bull; `;
                }

                return `
                <a href="/${post.slug}" class="group flex flex-col gap-2">
                    <div class="aspect-video relative rounded-xl overflow-hidden bg-surface-variant/10 border border-white/10 shadow-md">
                        <img src="${post.thumbnail_url || 'https://xmoviescdn.online/2018/08/logo.png'}" alt="${post.title}" loading="lazy" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
                        <div class="absolute bottom-2 right-2 bg-black/80 px-2 py-0.5 rounded text-xs font-medium backdrop-blur-sm">
                            ${post.runtime_minutes ? post.runtime_minutes + 'm' : 'HD'}
                        </div>
                        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
                            <span class="material-symbols-outlined text-white text-5xl opacity-0 group-hover:opacity-100 transition-opacity transform scale-50 group-hover:scale-100 duration-300 drop-shadow-lg">play_circle</span>
                        </div>
                    </div>
                    <div class="flex gap-3 mt-1">
                        <div class="w-9 h-9 rounded-full bg-surface-variant/30 flex-shrink-0 overflow-hidden flex items-center justify-center border border-white/10">
                            <span class="material-symbols-outlined text-on-surface-variant/50 text-sm">movie</span>
                        </div>
                        <div class="flex flex-col overflow-hidden">
                            <h3 class="text-white font-medium text-sm line-clamp-2 group-hover:text-primary transition-colors leading-snug" title="${post.title}">
                                ${post.title}
                            </h3>
                            <div class="text-xs text-on-surface-variant/80 mt-1 flex items-center gap-1">
                                ${studioHtml}
                                <span>${formatDate(post.published_at)}</span>
                            </div>
                        </div>
                    </div>
                </a>
                `;
            }

            
            fetch(`/api/related/${postId}`)
                .then(res => res.json())
                .then(res => {
                    const posts = res.data;
                    const container = document.getElementById('related-posts-container');
                    if (posts && posts.length > 0) {
                        const ads = [
                            document.getElementById('ad-in-feed-1').innerHTML,
                            document.getElementById('ad-in-feed-2').innerHTML,
                            document.getElementById('ad-in-feed-4').innerHTML
                        ];
                        let htmlStr = '';
                        posts.forEach((post, index) => {
                            htmlStr += renderCard(post);

                            
                            if ((index + 1) % 3 === 0) {
                                const adIndex = Math.floor((index + 1) / 3) - 1;
                                if (adIndex < ads.length) {
                                    htmlStr += `
                                    <article class="flex justify-center items-center w-full h-full min-h-[250px] bg-surface-variant/5 rounded-xl overflow-hidden shadow-md border border-white/5 relative group">
                                        <span class="absolute top-2 right-2 text-[10px] bg-surface text-on-surface-variant px-1 rounded opacity-50 z-20">AD</span>
                                        ${ads[adIndex]}
                                    </article>
                                    `;
                                }
                            }
                        });
                        container.innerHTML = htmlStr;
                    } else {
                        container.innerHTML = '<p class="text-on-surface-variant text-center col-span-full py-8">No related posts found.</p>';
                    }
                })
                .catch(err => console.error("Failed to load related posts:", err));


            
            fetch('/api/top-posts')
                .then(res => res.json())
                .then(res => {
                    const posts = res.data;
                    const container = document.getElementById('top-posts-container');
                    if (posts && posts.length > 0) {
                        
                        const top10 = posts.slice(0, 10);
                        container.innerHTML = top10.map((post, index) => {
                            let studioHtml = '';
                            if (post.studios && post.studios.length > 0) {
                                studioHtml = `<span class="text-primary font-medium truncate max-w-[100px]">${post.studios[0].name}</span> &bull; `;
                            }

                            return `
                            <a href="/${post.slug}" class="block relative group w-full mb-2">
                                <div class="aspect-video relative overflow-hidden bg-black rounded-lg border border-white/10">
                                    <img src="${post.thumbnail_url || 'https://xmoviescdn.online/2018/08/logo.png'}" alt="${post.title}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105 opacity-80 group-hover:opacity-100" loading="lazy" />
                                    <div class="absolute top-2 left-2 bg-primary text-on-primary font-bold px-2.5 py-1 rounded text-sm shadow-lg">#${index + 1}</div>
                                    <div class="absolute bottom-2 right-2 bg-black/80 px-2 py-0.5 rounded text-xs font-medium backdrop-blur-sm">${post.runtime_minutes ? post.runtime_minutes + 'm' : 'HD'}</div>
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
                                    
                                    <div class="absolute bottom-0 left-0 right-0 p-3">
                                        <h3 class="text-white font-bold text-sm line-clamp-2 leading-tight group-hover:text-primary transition-colors">${post.title}</h3>
                                        <div class="flex items-center gap-2 mt-1 text-xs text-gray-300">
                                            ${studioHtml}
                                            <span>${formatDate(post.published_at)}</span>
                                        </div>
                                    </div>
                                </div>
                            </a>
                            `;
                        }).join('');
                    } else {
                        container.innerHTML = '<p class="text-sm text-on-surface-variant">No top posts available.</p>';
                    }
                })
                .catch(err => console.error("Failed to load top posts:", err));

            
            if (postId) {
                navigator.sendBeacon("/api/visit/post/" + postId);
            }
        });
    </script>
